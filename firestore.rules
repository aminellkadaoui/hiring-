rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // الأدمن = حسابك أنت تحديداً (UID)، وليس أي مستخدم مسجّل
    function isAdmin() {
      return request.auth != null
             && request.auth.uid == 'tcWHqDIns1aPr8uUdGRMRR5TgDR2';
    }

    // إعدادات ومحتوى الصفحة: القراءة للجميع (الفورم يحتاجها)، التعديل للأدمن فقط
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // المتقدمون
    match /applicants/{id} {
      // أي زائر يرسل طلباً جديداً (إنشاء فقط)
      allow create: if true;

      // التحديث: الأدمن كامل الصلاحية، أو الزائر على حقلَي موافقة الترايل فقط
      allow update: if isAdmin()
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['trialConsent','declineReason']);

      // قراءة كل الطلبات وحذفها للأدمن فقط
      allow read, delete: if isAdmin();
    }
  }
}
